{
  "openapi": "3.0.3",
  "info": {
    "title": "Dashboard API",
    "description": "Dashboard REST API for managing customers, invoices, users, and revenues",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://dashboard-spring-data.onrender.com",
      "description": "Generated server url"
    }
  ],
  "security": [
    {
      "BearerAuthentication": []
    }
  ],
  "tags": [
    {
      "name": "Customers",
      "description": "Customer management operations"
    },
    {
      "name": "Revenues",
      "description": "Revenue data operations"
    },
    {
      "name": "Invoices",
      "description": "Invoice management operations"
    },
    {
      "name": "Activity",
      "description": "Activity feed operations"
    }
  ],
  "paths": {
    "/api/v1/invoices/{id}": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get invoice by ID",
        "description": "Retrieves a specific invoice by its ID",
        "operationId": "getInvoiceById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Invoice ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceRead"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Invoices"
        ],
        "summary": "Update invoice",
        "description": "Updates an existing invoice",
        "operationId": "updateInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Invoice ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InvoiceUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceRead"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Invoices"
        ],
        "summary": "Delete invoice",
        "description": "Soft deletes an invoice by its ID",
        "operationId": "deleteInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Invoice ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/customers/{id}": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "Get customer by ID",
        "description": "Retrieves a specific customer by their ID",
        "operationId": "getCustomerById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerRead"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Customers"
        ],
        "summary": "Update customer",
        "description": "Update existing customer",
        "operationId": "updateCustomer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerRead"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Customers"
        ],
        "summary": "Delete customer",
        "description": "Soft deletes a customer by its ID",
        "operationId": "deleteCustomer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices": {
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Create invoice",
        "description": "Creates a new invoice",
        "operationId": "createInvoice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InvoiceCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceRead"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices/search": {
      "post": {
        "tags": [
          "Invoices"
        ],
        "summary": "Search invoices",
        "description": "Searches invoices with pagination support",
        "operationId": "searchInvoices",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageReadInvoiceRead"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/customers": {
      "post": {
        "tags": [
          "Customers"
        ],
        "summary": "Create customer",
        "description": "Creates a new customer",
        "operationId": "createCustomer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerRead"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/customers/{id}/image": {
      "post": {
        "tags": [
          "Customers"
        ],
        "summary": "Upload image of the customer",
        "description": "Uploads an image of a customer",
        "operationId": "setImage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file"
                  }
                },
                "required": [
                  "file"
                ]
              },
              "encoding": {
                "file": {
                  "contentType": "multipart/form-data"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/revenues/": {
      "get": {
        "tags": [
          "Revenues"
        ],
        "summary": "Get all revenues",
        "description": "Retrieves monthly revenue data",
        "operationId": "getAllRevenues",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RevenueRead"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices/pages": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get page count",
        "description": "Returns the total number of pages for search results",
        "operationId": "getPages",
        "parameters": [
          {
            "name": "searchTerm",
            "in": "query",
            "description": "Search term to filter invoices",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Page size",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices/latest": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get latest invoices",
        "description": "Retrieves the most recent invoices with optional range parameters",
        "operationId": "getLatestInvoice",
        "parameters": [
          {
            "name": "indexFrom",
            "in": "query",
            "description": "Starting index",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "indexTo",
            "in": "query",
            "description": "Ending index",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/InvoiceRead"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices/count": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get invoice count",
        "description": "Returns the total number of invoices, optionally filtered by status",
        "operationId": "getInvoiceCount",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by invoice status",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices/amount": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get total invoice amount",
        "description": "Returns the sum of all invoice amounts, optionally filtered by status",
        "operationId": "getInvoiceAmount",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by invoice status",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invoices/": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get all invoices",
        "description": "Retrieves a list of all invoices",
        "operationId": "getAllInvoices",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/InvoiceRead"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/customers/count": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "Get customer count",
        "description": "Returns the total number of customers",
        "operationId": "getCustomerCount",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/customers/": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "Get all customers",
        "description": "Retrieves a list of all customers",
        "operationId": "getAllCustomers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CustomerRead"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/activity/recent": {
      "get": {
        "tags": [
          "Activity"
        ],
        "summary": "Get recent activity events",
        "description": "Retrieves the most recent activity events from the feed",
        "operationId": "getRecentEvents",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of events to return",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ActivityEvent"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "InvoiceUpdate": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number"
          },
          "customerId": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-fA-F0-9]{24}$"
          }
        },
        "required": [
          "customerId",
          "status"
        ]
      },
      "CustomerRead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "image_url": {
            "type": "string"
          }
        }
      },
      "InvoiceRead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "customer": {
            "$ref": "#/components/schemas/CustomerRead"
          }
        }
      },
      "CustomerUpdate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 1
          },
          "imageId": {
            "$ref": "#/components/schemas/ObjectId"
          }
        },
        "required": [
          "email",
          "id",
          "name"
        ]
      },
      "ObjectId": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "integer",
            "format": "int32"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InvoiceCreate": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number"
          },
          "customer_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-fA-F0-9]{24}$"
          }
        },
        "required": [
          "customer_id",
          "status"
        ]
      },
      "PageRequest": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "sort": {
            "type": "string"
          },
          "order": {
            "type": "string"
          },
          "search": {
            "type": "string"
          }
        }
      },
      "PageReadInvoiceRead": {
        "type": "object",
        "properties": {
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "currentPage": {
            "type": "integer",
            "format": "int32"
          },
          "itemsPerPage": {
            "type": "integer",
            "format": "int32"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceRead"
            }
          }
        }
      },
      "CustomerCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 1
          }
        },
        "required": [
          "email",
          "name"
        ]
      },
      "RevenueRead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "month": {
            "type": "string"
          },
          "revenue": {
            "type": "number"
          }
        }
      },
      "ActivityEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "actorId": {
            "type": "string"
          },
          "actorName": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {}
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuthentication": {
        "type": "http",
        "description": "Enter your JWT token",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}