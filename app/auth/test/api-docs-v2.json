    "/v2/oauth2/token": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Token endpoint (RFC 6749 §3.2)",
        "description": "Issues access and refresh tokens. Supports `authorization_code` (with PKCE) and `refresh_token` grant types. Responses include `Cache-Control: no-store` and `Pragma: no-cache` per RFC 6749 §5.1.",
        "operationId": "token",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "`authorization_code` or `refresh_token`"
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code (required for `authorization_code` grant)"
                  },
                  "code_verifier": {
                    "type": "string",
                    "description": "PKCE code verifier (required for `authorization_code` grant)"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Client ID (required for `authorization_code` grant)"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "Redirect URI (required for `authorization_code` grant)"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Client secret (required for confidential clients)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token (required for `refresh_token` grant)"
                  }
                },
                "required": [
                  "grant_type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens issued",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid grant or missing parameters",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/oauth2/revoke": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Token revocation endpoint (RFC 7009)",
        "description": "Revokes an access or refresh token. Always returns 200 even if the token is unknown or already revoked.",
        "operationId": "revoke",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "The token to revoke"
                  },
                  "token_type_hint": {
                    "type": "string",
                    "description": "Hint about the token type: `access_token` or `refresh_token`"
                  }
                },
                "required": [
                  "token"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked (or was already invalid)"
          }
        }
      }
    },
    "/v2/oauth2/introspect": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Token introspection endpoint (RFC 7662)",
        "description": "Allows resource servers to validate a token and retrieve its metadata. Requires HTTP Basic authentication using the service client secret.",
        "operationId": "introspect",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "HTTP Basic credentials (Base64 encoded `client_id:client_secret`)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "The token to introspect"
                  }
                },
                "required": [
                  "token"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Introspection result (active or inactive)",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/IntrospectionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Basic auth credentials"
          }
        }
      }
    },
    "/v2/oauth2/authorize": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Authorization endpoint — initiate (RFC 6749 §4.1.1)",
        "description": "Validates the authorization request and redirects the user-agent to the login page. Only `response_type=code` is supported. PKCE (`code_challenge` + `code_challenge_method`) is required.",
        "operationId": "authorize",
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "description": "Must be `code`",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "description": "Client identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "description": "Registered redirect URI",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge",
            "in": "query",
            "description": "PKCE code challenge (RFC 7636)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge_method",
            "in": "query",
            "description": "Must be `S256`",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "description": "Space-separated list of requested scopes",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Opaque value for CSRF protection, echoed back on redirect",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to login page (success) or redirect_uri with error",
            "headers": {
              "Location": {
                "description": "Login URL with request_id, or redirect_uri with error params",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Authorization endpoint — submit credentials",
        "description": "Called by the login form. Validates credentials and either issues an authorization code redirect or returns an `mfa_required` response if 2FA is enabled on the account.",
        "operationId": "submitAuthorize",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "request_id": {
                    "type": "string",
                    "description": "Authorization request ID from the GET /authorize redirect"
                  },
                  "username": {
                    "type": "string",
                    "description": "User email"
                  },
                  "password": {
                    "type": "string",
                    "description": "User password"
                  }
                },
                "required": [
                  "password",
                  "request_id",
                  "username"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "MFA required — contains mfa_token for the next step",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MfaRequiredResponse"
                }
              }
            }
          },
          "302": {
            "description": "Redirect to redirect_uri with authorization code",
            "headers": {
              "Location": {
                "description": "redirect_uri?code=...&state=...",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request_id",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/oauth2/authorize/mfa": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Authorization endpoint — complete MFA step",
        "description": "Called after receiving `mfa_required=true`. Validates the TOTP code and completes the authorization code redirect.",
        "operationId": "submitMfa",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "mfa_token": {
                    "type": "string",
                    "description": "MFA token received from POST /authorize"
                  },
                  "totp_code": {
                    "type": "string",
                    "description": "6-digit TOTP code from authenticator app"
                  }
                },
                "required": [
                  "mfa_token",
                  "totp_code"
                ]
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "MFA valid — redirect to redirect_uri with authorization code",
            "headers": {
              "Location": {
                "description": "redirect_uri?code=...&state=...",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired mfa_token",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid TOTP code",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
